# Copy this file to .env.local and fill in your project's values.
# Supabase Dashboard -> Project Settings -> API
#  - Project URL          -> VITE_SUPABASE_URL
#  - Publishable/anon key  -> VITE_SUPABASE_ANON_KEY  (safe for the browser; RLS protects data)
#
# .env.local is gitignored. NEVER put the service_role key in this app.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY
